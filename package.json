{
  "name": "cherry-studio-clone",
  "version": "0.1.0",
  "description": "Cherry Studio from-scratch clone — Electron + React + TypeScript AI desktop client",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:check": "pnpm lint && pnpm test",
    "lint": "eslint . --ext .ts,.tsx && tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "i18n:check": "node scripts/i18n-check.js"
  },
  "dependencies": {
    "@ai-sdk/azure": "^4.0.0",
    "@libsql/client": "^0.14.0",
    "drizzle-orm": "^0.44.2",
    "electron-updater": "^6.3.9",
    "highlight.js": "^11.11.1",
    "i18next": "^24.2.2",
    "ml-distance": "^4.0.1",
    "nanoid": "^5.1.11",
    "react-i18next": "^15.5.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tesseract.js": "^7.0.0",
    "ws": "^8.18.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/google": "^1.2.19",
    "@ai-sdk/openai": "^1.3.22",
    "@ai-sdk/provider": "^1.1.3",
    "@tailwindcss/vite": "^4.1.7",
    "@types/node": "^22.15.24",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "ai": "^4.3.16",
    "drizzle-kit": "^0.31.1",
    "electron": "^36.3.0",
    "electron-vite": "^3.1.0",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.1",
    "zod": "^3.25.28"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}